generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model meta_app_config {
  id                    Int       @id @default(1)
  app_id                String?
  app_secret            String?
  display_name          String?
  namespace             String?
  app_domains           String?
  contact_email         String?
  privacy_policy_url    String?
  terms_of_service_url  String?
  meta_verify_token     String?
  meta_page_access_token String?
  meta_ig_verify_token  String?
  meta_ig_access_token  String?
  admin_access_token    String?
  updated_at            DateTime? @default(now()) @updatedAt @db.Timestamp(6)
}

model permiso {
  id          Int           @id @default(autoincrement())
  nombre      String
  rol_permiso rol_permiso[]
}

model rol {
  id                                        Int           @id @default(autoincrement())
  nombre                                    String
  creado_en                                 DateTime?     @default(now()) @db.Timestamp(6)
  creado_por_id                             Int?
  actualizado_en                            DateTime?     @db.Timestamp(6)
  actualizado_por_id                        Int?
  usuarios_rol_actualizado_por_idTousuarios usuarios?     @relation("rol_actualizado_por_idTousuarios", fields: [actualizado_por_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rol_actualizado_por")
  usuarios_rol_creado_por_idTousuarios      usuarios?     @relation("rol_creado_por_idTousuarios", fields: [creado_por_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rol_creado_por")
  rol_permiso                               rol_permiso[]
  usuarios_usuarios_rol_idTorol             usuarios[]    @relation("usuarios_rol_idTorol")
}

model rol_permiso {
  rol_id     Int
  permiso_id Int
  permiso    permiso @relation(fields: [permiso_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  rol        rol     @relation(fields: [rol_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([rol_id, permiso_id])
}

model sesion {
  id                Int      @id @default(autoincrement())
  usuarioId         Int
  ip                String
  userAgent         String
  horaLogin         DateTime
  ultimaInteraccion DateTime
  activo            Boolean
  usuarios          usuarios @relation(fields: [usuarioId], references: [id])
}

model usuarios {
  id                                                   Int        @id @default(autoincrement())
  username                                             String     @unique
  password                                             String
  token_2fa                                            String
  rol_id                                               Int?
  nombre                                               String?
  apellido                                             String?
  run                                                  String?
  telefono                                             String?
  email                                                String?
  creado_en                                            DateTime?  @default(now()) @db.Timestamp(6)
  creado_por_id                                        Int?
  actualizado_en                                       DateTime?  @db.Timestamp(6)
  actualizado_por_id                                   Int?
  invitation_token                                     String?
  invitation_expires_at                                DateTime?  @db.Timestamp(6)
  invitation_attempts                                  Int        @default(0)
  reset_token                                          String?
  reset_token_expires                                  DateTime?  @db.Timestamp(6)
  mfa_bypass_token                                     String?
  mfa_new_secret                                       String?
  mfa_reset_expires                                    DateTime?  @db.Timestamp(6)
  login_attempts                                       Int        @default(0)
  bloqueado                                            Boolean    @default(false)
  bloqueado_en                                         DateTime?  @db.Timestamp(6)
  cancelado                                            Boolean    @default(false)
  protegido                                            Boolean    @default(false)
  photo_url                                            String?    @db.VarChar(500)
  rol_rol_actualizado_por_idTousuarios                 rol[]      @relation("rol_actualizado_por_idTousuarios")
  rol_rol_creado_por_idTousuarios                      rol[]      @relation("rol_creado_por_idTousuarios")
  sesion                                               sesion[]
  usuarios_usuarios_actualizado_por_idTousuarios       usuarios?  @relation("usuarios_actualizado_por_idTousuarios", fields: [actualizado_por_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuario_actualizado_por")
  other_usuarios_usuarios_actualizado_por_idTousuarios usuarios[] @relation("usuarios_actualizado_por_idTousuarios")
  usuarios_usuarios_creado_por_idTousuarios            usuarios?  @relation("usuarios_creado_por_idTousuarios", fields: [creado_por_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuario_creado_por")
  other_usuarios_usuarios_creado_por_idTousuarios      usuarios[] @relation("usuarios_creado_por_idTousuarios")
  rol_usuarios_rol_idTorol                             rol?       @relation("usuarios_rol_idTorol", fields: [rol_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model precios_planes {
  codigo                        String   @id
  nombre                        String?
  precio_base                   Decimal? @db.Decimal
  tipo                          String?
  descripcion                   String?
  lineas                        Int?
  excluye_alta                  Boolean? @default(false)
  excluye_portabilidad_postpago Boolean? @default(false)
  url_archivo                   String?  @db.VarChar(255)
  precio_normal                 Int?
}

model respuestas_rapidas {
  uuid  String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  atajo String @unique @db.VarChar(50)
  texto String
}

model actor_history_score {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_external_id String
  external_event_id String   @unique
  score_delta       Decimal  @db.Decimal(10, 4)
  signal_type       String
  metadata          Json?
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  @@index([actor_external_id, created_at(sort: Desc)], map: "idx_actor_history_score_actor_time")
  @@index([created_at(sort: Desc)], map: "idx_actor_history_score_created")
}

model actor_lifecycle {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_external_id String
  state             actor_state
  occurred_at       DateTime    @default(now()) @db.Timestamptz(6)

  @@index([actor_external_id, occurred_at(sort: Desc)], map: "idx_actor_lifecycle_actor_time")
  @@index([state], map: "idx_actor_lifecycle_state")
}

model actor_score {
  actor_external_id String   @id
  score             Decimal  @default(0) @db.Decimal(10, 4)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)

  @@index([updated_at(sort: Desc)], map: "idx_actor_score_updated")
}

model event_history {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  external_event_id String           @unique
  actor_external_id String
  provider          provider_type
  object_type       meta_object_type
  pipeline          pipeline_type
  event_type        String
  payload           Json
  occurred_at       DateTime         @db.Timestamptz(6)
  received_at       DateTime         @default(now()) @db.Timestamptz(6)

  @@index([actor_external_id, occurred_at(sort: Desc)], map: "idx_event_history_actor_time")
  @@index([received_at(sort: Desc)], map: "idx_event_history_received")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model n8n_chat_history {
  id                            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  external_event_id             String             @unique @db.VarChar(255)
  message_external_id           String?            @db.VarChar(255)
  actor_external_id             String             @db.VarChar(255)
  thread_external_id            String?            @db.VarChar(255)
  in_reply_to_external_event_id String?            @db.VarChar(255)
  correlation_id                String?            @db.VarChar(255)
  causation_id                  String?            @db.VarChar(255)
  provider                      String             @db.VarChar(32)
  object_type                   String             @db.VarChar(32)
  pipeline                      String             @default("MESSAGES") @db.VarChar(32)
  event_type                    String             @db.VarChar(64)
  source_system                 String             @db.VarChar(32)
  source_channel                String             @db.VarChar(32)
  source_event_id               String?            @db.VarChar(255)
  direction                     String             @db.VarChar(16)
  content_type                  String             @db.VarChar(32)
  content_text                  String?
  content_json                  Json?
  status                        String             @default("received") @db.VarChar(32)
  signal_type                   String?            @db.VarChar(64)
  error_code                    String?            @db.VarChar(64)
  error_message                 String?
  workflow_id                   String?            @db.VarChar(128)
  workflow_execution_id         String?            @db.VarChar(128)
  queue_name                    String?            @db.VarChar(64)
  job_name                      String?            @db.VarChar(64)
  job_id                        String?            @db.VarChar(255)
  attempt                       Int?
  max_attempts                  Int?
  job_status                    String?            @db.VarChar(32)
  queued_at                     DateTime?          @db.Timestamptz(6)
  started_at                    DateTime?          @db.Timestamptz(6)
  finished_at                   DateTime?          @db.Timestamptz(6)
  metadata                      Json?
  payload                       Json               @default("{}")
  occurred_at                   DateTime           @db.Timestamptz(6)
  received_at                   DateTime           @default(now()) @db.Timestamptz(6)
  created_at                    DateTime           @default(now()) @db.Timestamptz(6)
  updated_at                    DateTime           @default(now()) @db.Timestamptz(6)
  n8n_chat_history              n8n_chat_history?  @relation("n8n_chat_historyTon8n_chat_history", fields: [in_reply_to_external_event_id], references: [external_event_id], map: "fk_n8n_chat_in_reply")
  other_n8n_chat_history        n8n_chat_history[] @relation("n8n_chat_historyTon8n_chat_history")

  @@index([actor_external_id, occurred_at(sort: Desc)], map: "idx_n8n_chat_actor_time")
  @@index([direction, occurred_at(sort: Desc)], map: "idx_n8n_chat_direction_time")
  @@index([queue_name, job_name, job_id], map: "idx_n8n_chat_job")
  @@index([in_reply_to_external_event_id], map: "idx_n8n_chat_reply_to")
  @@index([status, occurred_at(sort: Desc)], map: "idx_n8n_chat_status_time")
  @@index([thread_external_id, occurred_at(sort: Desc)], map: "idx_n8n_chat_thread_time")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
