/// This model contains an index with non-default null sort order and requires additional setup for migrations. Visit https://pris.ly/d/default-index-null-ordering for more info.
model threads {
  id                               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id                       String    @unique @db.VarChar(255)
  actor_external_id                String    @db.VarChar(255)
  object_type                      String    @db.VarChar(32)
  source_channel                   String?   @db.VarChar(32)
  thread_status                    String    @default("OPEN") @db.VarChar(32)
  attention_mode                   String    @default("N8N") @db.VarChar(32)
  thread_stage                     String    @default("inicio") @db.VarChar(64)
  last_message_text                String?
  last_direction                   String?   @db.VarChar(16)
  last_message_at                  DateTime? @db.Timestamptz(6)
  last_incoming_at                 DateTime? @db.Timestamptz(6)
  last_outgoing_at                 DateTime? @db.Timestamptz(6)
  opened_at                        DateTime  @default(now()) @db.Timestamptz(6)
  paused_at                        DateTime? @db.Timestamptz(6)
  archived_at                      DateTime? @db.Timestamptz(6)
  closed_at                        DateTime? @db.Timestamptz(6)
  metadata                         Json      @default("{}")
  created_at                       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at                       DateTime  @default(now()) @db.Timestamptz(6)
  awaiting_first_incoming_delegate Boolean   @default(false)

  @@index([actor_external_id, object_type], map: "idx_threads_actor_object")
  @@index([thread_status, last_message_at(sort: Desc)], map: "idx_threads_status_last_message")
}

enum actor_state {
  NEW
  CHURNED
  QUALIFIED
  BLOCKED
}

enum score_operator {
  lt
  lte
  gt
  gte
  eq
}

enum meta_object_type {
  PAGE
  INSTAGRAM
  WHATSAPP
}

enum pipeline_type {
  MESSAGES
  CHANGES
  TRANSITIONS
}

enum provider_type {
  META
  BAILEYS
}

enum offer_modality {
  POST_A_POST
  SALTA
  PRE_A_POST
  ALTA
}

/// Catálogo de ofertas: (code + modality) determina level (1-9) y points (0–3 en pasos de 0.5)
model offer {
  id       Int            @id @default(autoincrement())
  code     String         @db.VarChar(20)
  modality offer_modality
  level    Int
  points   Decimal        @db.Decimal(3, 1)

  sales sale_record[]

  @@unique([code, modality])
  @@map("offers")
}

/// Matriz de precios: level (1-9) × range (1-3) → price
/// range 1: total_points < 20 | range 2: 20 ≤ total < 35 | range 3: ≥ 35
model price_level {
  id    Int     @id @default(autoincrement())
  level Int
  range Int
  price Int

  @@unique([level, range])
}

/// Acumulado de puntos por mes-año; determina el rango activo del mes
model points_level {
  id           Int     @id @default(autoincrement())
  year         Int     @db.SmallInt
  month        Int     @db.SmallInt
  total_points Decimal @default(0) @db.Decimal(8, 1)

  @@unique([year, month])
}

/// Ventas manuales. level_price, points y offers_price se calculan automáticamente.
/// offers_price se recalcula en bulk cuando total_points del mes cruza 20 o 35.
model sale_record {
  id              Int            @id @default(autoincrement())
  fecha           DateTime       @db.Date
  run             String         @db.VarChar(12)
  full_name       String         @db.VarChar(200)
  phone           String         @db.VarChar(30)
  address         String         @db.VarChar(300)
  city            String         @db.VarChar(100)
  province        String         @db.VarChar(100)
  country         String         @db.VarChar(100)
  contract_number String         @db.VarChar(100)
  modality        offer_modality
  offers_code     String         @db.VarChar(20)
  offer_id        Int
  offer           offer          @relation(fields: [offer_id], references: [id])
  level_price     Int
  points          Decimal        @db.Decimal(3, 1)
  offers_price    Int
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  updated_at      DateTime       @default(now()) @db.Timestamptz(6) @updatedAt

  @@index([fecha(sort: Desc)], map: "idx_sale_record_fecha")
  @@index([offer_id], map: "idx_sale_record_offer")
  @@map("sales_record")
}

model wa_ad_leads {
  id                 String    @id @default(uuid()) @db.Uuid
  source_id          String?
  session_id         String?   @db.VarChar
  actor_external_id  String?   @db.VarChar
