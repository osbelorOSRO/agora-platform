  lid_jid            String?   @db.VarChar
  source_url         String?
  title              String?
  thumbnail_url      String?
  original_image_url String?
  first_message_text String?
  metadata           Json?
  first_seen_at      DateTime? @db.Timestamptz(6)
  last_seen_at       DateTime? @db.Timestamptz(6)
  seen_count         Int?      @default(0)
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
  updated_at         DateTime? @updatedAt @db.Timestamptz(6)

  @@index([source_id, first_seen_at(sort: Desc)], name: "idx_wa_ad_leads_source_seen")
  @@index([session_id], name: "idx_wa_ad_leads_session")
}
