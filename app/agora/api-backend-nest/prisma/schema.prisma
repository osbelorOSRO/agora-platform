  session_id                    String   @db.VarChar(255)
  external_event_id             String   @unique @db.VarChar(255)
  message_external_id           String?  @db.VarChar(255)
  actor_external_id             String   @db.VarChar(255)
  provider                      String   @db.VarChar(32)
  object_type                   String   @db.VarChar(32)
  source_channel                String?  @db.VarChar(32)
  event_kind                    String   @db.VarChar(64)
  direction                     String   @db.VarChar(16)
  content_text                  String?
  content_json                  Json     @default("{}")
  in_reply_to_external_event_id String?  @db.VarChar(255)
  status                        String   @default("received") @db.VarChar(32)
  signal_type                   String?  @db.VarChar(64)
  workflow_execution_id         String?  @db.VarChar(128)
  occurred_at                   DateTime @db.Timestamptz(6)
  received_at                   DateTime @default(now()) @db.Timestamptz(6)
  created_at                    DateTime @default(now()) @db.Timestamptz(6)
