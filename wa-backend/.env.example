NODE_ENV=production
API_PORT=3000
TRUST_PROXY=true
LOG_LEVEL=info
PROXY_TIMEOUT=120000
AUTH_FOLDER=auth

API_BACKEND_URL=http://api_backend_nest:4001
MEDIA_BASE_URL=https://api.example.com
WS_URL=http://panel_websocket:5050
N8N_WEBHOOK_URL=http://n8n:5678/webhook/flujo-ventas

VAULT_ADDR=http://vault:8200
VAULT_ROLE_ID=<vault_role_id>
VAULT_SECRET_ID=<vault_secret_id>
VAULT_TIMEOUT=5000
VAULT_TOKEN_RENEW_INTERVAL=30

VAULT_PATH_BOT_PRIVATE_KEY=accesos/keys/bot-private
VAULT_PATH_BACKEND_PUBLIC_KEY=accesos/keys/public
VAULT_PATH_SOCKET_SECRET=accesos/bot
VAULT_FIELD_RSA_KEY=key
VAULT_FIELD_SOCKET_SECRET=secret_key_wa
