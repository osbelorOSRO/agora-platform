generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model clientes {
  cliente_id         String           @id
  nombre             String?
  fecha_registro     DateTime?        @default(now()) @db.Timestamp(6)
  estado_actual      Int?
  fecha_actual       DateTime?        @db.Timestamp(6)
  intervenida        Boolean          @default(false)
  foto_perfil        String?
  etiqueta_actual    String?
  tipo_id            String           @default("jid") @db.VarChar(10)
  creado_por_id      Int?
  actualizado_por_id Int?
  conversaciones     conversaciones[]
  map_journey        map_journey[]

  @@index([cliente_id, tipo_id], map: "idx_clientes_cliente_tipo")
  @@index([tipo_id], map: "idx_clientes_tipo_id")
  @@index([fecha_registro(sort: Desc)], map: "idx_clientes_fecha_registro")
}

model colores {
  color_id   Int         @id @default(autoincrement())
  bg_class   String?
  text_class String?
  etiquetas  etiquetas[]
}

model configuracion_bot {
  id                 Int       @id @default(autoincrement())
  tipo_configuracion String    @unique
  activo             Boolean?  @default(true)
  updated_at         DateTime? @default(now()) @db.Timestamp(6)
}

model conversaciones {
  id                Int       @id @default(autoincrement())
  cliente_id        String?
  contenido         String?
  tipo              String?
  url_archivo       String?
  direccion_mensaje String?
  origen            String?
  fecha_envio       DateTime? @db.Timestamp(6)
  etiqueta_id       Int?
  fuente            String?
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  clientes          clientes? @relation(fields: [cliente_id], references: [cliente_id], onDelete: NoAction, onUpdate: NoAction)
}

model etiquetas {
  etiqueta_id     Int           @id @default(autoincrement())
  nombre_etiqueta String        @unique
  color_id        Int?
  colores         colores?      @relation(fields: [color_id], references: [color_id], onDelete: NoAction, onUpdate: NoAction)
  map_journey     map_journey[]
}

model map_journey {
  id              Int        @id @default(autoincrement())
  cliente_id      String?
  etiqueta_id     Int?
  fuente          String?
  fecha           DateTime?  @default(now()) @db.Timestamptz(6)
  proceso_id      Int?
  lead_calificado Boolean    @default(true)
  clientes        clientes?  @relation(fields: [cliente_id], references: [cliente_id], onDelete: NoAction, onUpdate: NoAction)
  etiquetas       etiquetas? @relation(fields: [etiqueta_id], references: [etiqueta_id], onDelete: NoAction, onUpdate: NoAction)
  procesos        procesos?  @relation(fields: [proceso_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([cliente_id], map: "idx_map_journey_cliente_id")
  @@index([proceso_id], map: "idx_map_journey_proceso_id")
}

model mensajes_buffer {
  id           Int       @id @default(autoincrement())
  cliente_id   String
  contenido    String
  fecha        DateTime? @default(now()) @db.Timestamp(6)
  hash_mensaje String?   @unique(map: "idx_hash_mensaje")

  @@unique([cliente_id, hash_mensaje], map: "mensajes_buffer_unique")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model n8n_chat_histories {
  id         Int       @id @default(autoincrement())
  session_id String
  role       String
  message    String
  timestamp  DateTime? @default(now()) @db.Timestamp(6)
}

model oficinas {
  id       Int        @id @default(autoincrement())
  nombre   String
  region   String?    @default("Online")
  usuarios usuarios[]
}

model permiso {
  id          Int           @id @default(autoincrement())
  nombre      String
  rol_permiso rol_permiso[]
}

model procesos {
  id                                          Int           @id @default(autoincrement())
  cliente_id                                  String
  fecha_inicio                                DateTime      @default(now()) @db.Timestamp(6)
  fecha_fin                                   DateTime?     @db.Timestamp(6)
  iniciado_por_id                             Int
  cerrado_por_id                              Int?
  tipo_proceso                                String?
  tipo_cierre                                 String?
  duracion_total                              Int?
  sla_humano                                  Int?
  tmo                                         Int?
  delegado_humano                             Boolean?      @default(false)
  abandono                                    Boolean?      @default(false)
  duracion_valor                              BigInt?
  duracion_unidad                             String?       @db.VarChar(10)
  fecha_saludo                                DateTime?     @db.Timestamp(6)
  session_mode                                String?       @db.VarChar(20)
  map_journey                                 map_journey[]
  usuarios_procesos_cerrado_por_idTousuarios  usuarios?     @relation("procesos_cerrado_por_idTousuarios", fields: [cerrado_por_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuarios_procesos_iniciado_por_idTousuarios usuarios      @relation("procesos_iniciado_por_idTousuarios", fields: [iniciado_por_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([cliente_id, fecha_fin], map: "idx_procesos_cliente_fecha")
  @@index([cliente_id], map: "idx_procesos_cliente_id")
}

model procesos_en_curso {
  cliente_id String    @id
  creado_en  DateTime? @default(now()) @db.Timestamp(6)
}

model rol {
  id                                        Int           @id @default(autoincrement())
  nombre                                    String
  creado_en                                 DateTime?     @default(now()) @db.Timestamp(6)
  creado_por_id                             Int?
  actualizado_en                            DateTime?     @db.Timestamp(6)
  actualizado_por_id                        Int?
  usuarios_rol_actualizado_por_idTousuarios usuarios?     @relation("rol_actualizado_por_idTousuarios", fields: [actualizado_por_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rol_actualizado_por")
  usuarios_rol_creado_por_idTousuarios      usuarios?     @relation("rol_creado_por_idTousuarios", fields: [creado_por_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rol_creado_por")
  rol_permiso                               rol_permiso[]
  usuarios_usuarios_rol_idTorol             usuarios[]    @relation("usuarios_rol_idTorol")
}

model rol_permiso {
  rol_id     Int
  permiso_id Int
  permiso    permiso @relation(fields: [permiso_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  rol        rol     @relation(fields: [rol_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([rol_id, permiso_id])
}

model sesion {
  id                Int      @id @default(autoincrement())
  usuarioId         Int
  ip                String
  userAgent         String
  horaLogin         DateTime
  ultimaInteraccion DateTime
  activo            Boolean
  usuarios          usuarios @relation(fields: [usuarioId], references: [id])
}

model transiciones_comerciales {
  id                 Int     @id @default(autoincrement())
  etiqueta_id_origen Int     @unique(map: "idx_etiqueta_id_origen")
  mensaje_bot        String?
  opcion_1           String?
  opcion_2           String?
  opcion_3           String?
  opcion_4           String?
  destino_1          Int?
  destino_2          Int?
  destino_3          Int?
  destino_4          Int?
  fallback_texto     String?
  etiqueta_anterior  String?
  silent             Boolean @default(false)
  sub_estado         String?
  flujo_logico       String?
  consulta_equipo    String?
  fallback1          String?
  fallback2          String?
  destino_humano     String?
  texto_rescate      String?
  modo_default       String?
  nueva_etiqueta1    Int?
  nueva_etiqueta2    Int?
  nueva_etiqueta3    Int?
}

model usuarios {
  id                                                   Int         @id @default(autoincrement())
  username                                             String      @unique
  password                                             String
  token_2fa                                            String
  rol_id                                               Int?
  oficina_id                                           Int?
  nombre                                               String?
  apellido                                             String?
  run                                                  String?
  telefono                                             String?
  email                                                String?
  creado_en                                            DateTime?   @default(now()) @db.Timestamp(6)
  creado_por_id                                        Int?
  actualizado_en                                       DateTime?   @db.Timestamp(6)
  actualizado_por_id                                   Int?
  contratos                                            contratos[]
  procesos_procesos_cerrado_por_idTousuarios           procesos[]  @relation("procesos_cerrado_por_idTousuarios")
  procesos_procesos_iniciado_por_idTousuarios          procesos[]  @relation("procesos_iniciado_por_idTousuarios")
  rol_rol_actualizado_por_idTousuarios                 rol[]       @relation("rol_actualizado_por_idTousuarios")
  rol_rol_creado_por_idTousuarios                      rol[]       @relation("rol_creado_por_idTousuarios")
  sesion                                               sesion[]
  usuarios_usuarios_actualizado_por_idTousuarios       usuarios?   @relation("usuarios_actualizado_por_idTousuarios", fields: [actualizado_por_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuario_actualizado_por")
  other_usuarios_usuarios_actualizado_por_idTousuarios usuarios[]  @relation("usuarios_actualizado_por_idTousuarios")
  usuarios_usuarios_creado_por_idTousuarios            usuarios?   @relation("usuarios_creado_por_idTousuarios", fields: [creado_por_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuario_creado_por")
  other_usuarios_usuarios_creado_por_idTousuarios      usuarios[]  @relation("usuarios_creado_por_idTousuarios")
  oficinas                                             oficinas?   @relation(fields: [oficina_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rol_usuarios_rol_idTorol                             rol?        @relation("usuarios_rol_idTorol", fields: [rol_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
