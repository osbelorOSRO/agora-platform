MICROSERVICIO_MONGO_URI=mongodb://<db_user>:<db_password>@<mongo_host>:27017/?authSource=admin


REDIS_PASSWORD=<redis_password>

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=<pgadmin_password>
