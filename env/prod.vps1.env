WA_PUBLIC_URL=https://wsapi.example.com
VAULT_PUBLIC_URL=http://<host_bind_ip>:8200
PGADMIN_PUBLIC_URL=http://<host_bind_ip>:8080
NPM_UI_PUBLIC_URL=https://nmp.example.com
MEDIA_BASE_URL=https://api.example.com

API_INTERNAL_URL=http://api_backend_nest:4001
ABACKEND_INTERNAL_URL=http://abackend:4002
WS_INTERNAL_URL=http://panel_websocket:5050
N8N_INTERNAL_URL=http://n8n:5678
WA_INTERNAL_URL=http://wa_backend:3000
VAULT_INTERNAL_URL=http://vault:8200
VAULT_ADDR=<vault_addr>
VAULT_ROLE_ID=<vault_role_id_n8n_services>
VAULT_SECRET_ID=<vault_secret_id_n8n_services>
