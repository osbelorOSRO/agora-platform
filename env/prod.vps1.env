APP_ENV=prod
TARGET_HOST=vps1
HOST_BIND_IP=<host_bind_ip>
DOMAIN_BASE=example.com
HTTP_SCHEME=https
WS_SCHEME=wss

FRONTEND_PUBLIC_URL=https://prefijo.example.com
API_PUBLIC_URL=https://prefijo.example.com
ABACKEND_PUBLIC_URL=https://prefijo.example.com
WS_PUBLIC_URL=wss://prefijo.example.com
N8N_PUBLIC_URL=https://prefijo.example.com
WA_PUBLIC_URL=https://prefijo.example.com
WA_WS_PUBLIC_URL=wss://prefijo.example.com
VAULT_PUBLIC_URL=http://<host_bind_ip>:PORT
PGADMIN_PUBLIC_URL=http://<host_bind_ip>:PORT
NPM_UI_PUBLIC_URL=https://prefijo.example.com
MEDIA_BASE_URL=https://prefijo.example.com
UPLOADS_DIR=<uploads_dir>
FRONTEND_CSP_SCRIPT_SRC="'self' 'unsafe-inline'"
FRONTEND_CSP_STYLE_SRC="'self' 'unsafe-inline' https://fonts.googleapis.com"
FRONTEND_CSP_FONT_SRC="'self' https://fonts.gstatic.com"
FRONTEND_CSP_CONNECT_SRC="'self' https://prefijo.example.com wss://prefijo.example.com"
FRONTEND_CSP_IMG_SRC="'self' data: blob: https://prefijo.example.com https://facebook.com https://www.facebook.com https://*.facebook.com https://fbcdn.net https://*.fbcdn.net https://pps.whatsapp.net https://lookaside.fbsbx.com"
FRONTEND_CSP_MEDIA_SRC="'self' data: blob: https://prefijo.example.com"

API_INTERNAL_URL=https://prefijo.example.com
ABACKEND_INTERNAL_URL=https://prefijo.example.com
WS_INTERNAL_URL=https://prefijo.example.com
N8N_INTERNAL_URL=https://prefijo.example.com
WA_INTERNAL_URL=https://prefijo.example.com
VAULT_INTERNAL_URL=https://prefijo.example.com
VAULT_ADDR=<vault_addr>
VAULT_ROLE_ID=<vault_role_id_n8n_services>
VAULT_SECRET_ID=<vault_secret_id_n8n_services>
VAULT_N8N_SECRET_PATH=secret/data/n8n/ambiente
BAILEYS_INTERNAL_TOKEN=<token-secret>
API_VAULT_APP_SECRETS_PATH=ambiente/example/api_contendedor
REDIS_INTERNAL_URL=https://prefijo.example.com
WHISPER_INTERNAL_URL=https://prefijo.example.com
TESSERACT_INTERNAL_URL=https://prefijo.example.com
SCRAPER_BASE_URL=https://prefijo.example.com

SOCKET_HTTP_PUBLIC_URL=https://prefijo.example.com
GATEWAY_BASE_URL=https://prefijo.example.com
SERVICE_ALLOWED_IPS=<comma_separated_allowed_ips>
API_DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>:PORT/<db_name>
ABACKEND_DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>:PORT/<db_name>?schema=public


REDIS_PASSWORD=<redis_password>

PGADMIN_DEFAULT_EMAIL=<pgadmin_default_email>
PGADMIN_DEFAULT_PASSWORD=<pgadmin_password>
