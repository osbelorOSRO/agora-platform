HOST_BIND_IP=<host_bind_ip>
N8N_DATA_TYPE=<bind|volume>
N8N_DATA_VOLUME=<path_or_volume_name>
N8N_ENV_FILE=./env/dev.local1.env
N8N_HOST=<url-example>
N8N_PROTOCOL=http
N8N_PORT=PORT
N8N_LISTEN_ADDRESS=0.0.0.0
WEBHOOK_URL=<url-example>
N8N_EDITOR_BASE_URL=<url-example>
N8N_SECURE_COOKIE=false
N8N_TRUST_PROXY=true
N8N_CUSTOM_API_TOKEN=<url-example>  
N8N_CUSTOM_API_SCRAPER=<url-example>
N8N_CUSTOM_API_STATUS=<url-example>  
N8N_CUSTOM_WHISPER=http=<url-example>
N8N_CUSTOM_TESSERACT=<url-example>
N8N_CUSTOM_API_DAEMON=<url-example>
N8N_CUSTOM_API_CALLBACK=<url-example>
N8N_BASIC_AUTH_USER=<n8n_basic_auth_user>
N8N_BASIC_AUTH_PASSWORD=<n8n_basic_auth_password>
N8N_API_KEY_X=<n8n_api_key_x>
N8N_CUSTOM_SECRET_KEY=<n8n_custom_secret_key>
N8N_API_KEY_CALLBACK=<n8n_api_key_callback>
N8N_RUNNERS_AUTH_TOKEN=<n8n_runners_auth_token>
