# Secrets by profile (keep local only)
app/env/*.secrets.env
n8n/env/*.secrets.env

# Local runtime secrets/services
app/agora/.env
app/agora/frontend/.env
app/agora/websocket/.env
app/accesos/abackend/.env
app/agora/api-backend-nest/.env
app/wa-backend/.env

# Local exports and backups
*.secrets
*.secret
*.key
*.pem
*.crt
*.pfx
*.p12

# TLS cert material / local cert exports
Cloudfare Certs/
nmp/letsencrypt/

# Runtime auth/session material
app/wa-backend/auth/*.json
app/wa-backend/auth_info_baileys/
redis/
n8n/n8n-data/

infraestructura/

# DB exports / dumps / backups
infraestructura/postgres-init/*.sql
mongo/mongo-init/*.archive
mongo/mongo-init/*.dump
mongo/mongo-init/dump/
*.bak
*.backup

# Build/deps artifacts
**/node_modules/
**/dist/
**/.cache/
**/*.tsbuildinfo

# Local service runtime data/config that should not be in repo
nmp/
n8n/whisper/models/
uploads/

# Mongo seed/restore kept out of repo
mongo/mongo-init/

