# Etapa 1: Build
FROM node:24-alpine AS builder

WORKDIR /app

ARG VITE_WEBSOCKET_URL
ARG VITE_API_URL
ARG VITE_MEDIA_BASE_URL
ARG VITE_AUTH_API_URL
ARG VITE_ESTADO_BOT_URL
ARG VITE_API_URL_ACCESOS
ARG VITE_SCRAPER_BASE_URL
ARG VITE_WA_PUBLIC_URL

ENV VITE_WEBSOCKET_URL=$VITE_WEBSOCKET_URL
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_MEDIA_BASE_URL=$VITE_MEDIA_BASE_URL
ENV VITE_AUTH_API_URL=$VITE_AUTH_API_URL
ENV VITE_ESTADO_BOT_URL=$VITE_ESTADO_BOT_URL
ENV VITE_API_URL_ACCESOS=$VITE_API_URL_ACCESOS
ENV VITE_SCRAPER_BASE_URL=$VITE_SCRAPER_BASE_URL
ENV VITE_WA_PUBLIC_URL=$VITE_WA_PUBLIC_URL

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

# Etapa 2: Nginx
FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
